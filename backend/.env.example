# --- Database ---
DATABASE_URL=sqlite:///./civil_supplies.db
# For Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/civil_supplies

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TO=owner@yourcompany.com

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Seed ---
SEED_ADMIN_EMAIL=admin@civilsupplies.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
# Set these in production to send BOQ uploads to S3 instead of local disk:
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# --- App ---
APP_NAME=Civil Supplies API
ENVIRONMENT=development
