# --- Database ---
# SQLite (default, easy start)
DATABASE_URL=sqlite:///./civil_supplies.db
# For Postgres later:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/civil_supplies

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Email (SMTP) ---
# For Gmail use app password, or use SendGrid/AWS SES SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TO=owner@yourcompany.com

# --- App ---
APP_NAME=Civil Supplies API
ENVIRONMENT=development
