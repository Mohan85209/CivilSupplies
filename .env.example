# Root environment variables for local development and docker-compose
# Copy to .env and edit as needed before running.
# Never commit .env — only this example file.

# --- Postgres ---------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=civilsupplies

# --- Backend (Spring Boot) --------------------------------------------------
APP_PROFILE=prod
# JDBC URL — compose value already wired in docker-compose.yml
DATABASE_URL=jdbc:postgresql://postgres:5432/civilsupplies

# JWT signing secret. Must be >= 32 bytes. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-secure-random-string-of-at-least-32-bytes

# CORS — comma separated origins (no trailing slash)
CORS_ORIGINS=http://localhost,http://localhost:4200

# Notification routing
MAIL_FROM=no-reply@civilsupplies.in
ADMIN_NOTIFY_TO=sales@civilsupplies.in

# Upload directory inside the container
UPLOAD_DIR=/app/uploads

# Storage backend: local | s3
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=ap-south-1

# Rate limit overrides (per hour, per client IP)
RATELIMIT_ENQUIRIES_PER_HOUR=10
RATELIMIT_QUOTES_PER_HOUR=5
RATELIMIT_NEWSLETTER_PER_HOUR=5

# --- Email (SMTP / AWS SES) -------------------------------------------------
# In production point at SES SMTP credentials.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- AWS (production deployment) --------------------------------------------
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# --- Frontend (Angular) -----------------------------------------------------
# Public origin where the site is served from.
PUBLIC_SITE_URL=http://localhost

# GSTIN displayed in footer.
PUBLIC_GST_NUMBER=36ABCDE1234F1Z5

# WhatsApp Business number (digits only, with country code, no '+').
PUBLIC_WHATSAPP_NUMBER=919876543210
