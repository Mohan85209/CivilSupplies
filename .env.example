# Root environment variables for local development and docker-compose
# Copy to .env and edit as needed before running.
# Never commit .env — only this example file.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=civilsupplies

# --- Backend (FastAPI) ------------------------------------------------------
# Example for compose: postgresql+psycopg2://postgres:postgres@postgres:5432/civilsupplies
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/civilsupplies

# Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-a-secure-random-string
JWT_EXPIRE_MINUTES=1440
SEED_ADMIN_PASSWORD=ChangeMe123!
UPLOAD_DIR=./uploads

# CORS — comma separated origins
CORS_ORIGINS=http://localhost:3000

# Owner email — where contact/enquiry notifications are routed
OWNER_EMAIL=mohankumarsatyavarapu225@gmail.com

# --- Email (SMTP / AWS SES) -------------------------------------------------
# In production these point at AWS SES SMTP credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# --- AWS (used in production) -----------------------------------------------
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# --- Frontend (Next.js) -----------------------------------------------------
# Public URL where the site is served from — used by metadataBase and og:url.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend base URL the browser will call.
NEXT_PUBLIC_API_URL=http://localhost:8000

# GSTIN to show in the footer / contact page.
NEXT_PUBLIC_GST_NUMBER=36ABCDE1234F1Z5

# WhatsApp Business number (digits only, with country code, no '+').
NEXT_PUBLIC_WHATSAPP_NUMBER=918520933400

# LinkedIn profile URL shown on the contact page.
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/mohan-kumar-satyavarapu/
